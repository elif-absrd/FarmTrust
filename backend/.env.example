# ===== DATABASE CONFIGURATION =====
# PostgreSQL connection details
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=farmtrust
# Full connection string (auto-generated from above, can override)
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/farmtrust?schema=public

# ===== SERVER CONFIGURATION =====
# Backend Express server port
PORT=5000
# Environment mode (development, production)
NODE_ENV=development
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8082,http://127.0.0.1:8082,http://localhost:3000

# ===== JWT CONFIGURATION =====
# JWT token secret (change this in production!)
JWT_SECRET=your_jwt_secret_key_change_this_in_production
# JWT token expiration
JWT_EXPIRE=7d

# ===== SERVICES CONFIGURATION =====
# NDVI Service URL (Python service for satellite data)
NDVI_SERVICE_URL=http://localhost:8000
# Backend service URL (used by NDVI service for callbacks)
BACKEND_URL=http://localhost:5000
# Whether to sync NDVI on server startup
NDVI_SYNC_ON_START=false
# Frontend URL (Expo app running on mobile or web)
FRONTEND_URL=http://localhost:8082

# ===== BLOCKCHAIN CONFIGURATION =====
# Polygon Testnet (Amoy) RPC endpoint
POLYGON_TESTNET_RPC_URL=https://rpc-amoy.polygon.technology
# Private key for deploying contracts (do NOT commit this to git!)
POLYGON_TESTNET_PRIVATE_KEY=your_private_key_here
# Network name
POLYGON_TESTNET_NETWORK=polygon-amoy
# Farm Identity contract address (deployed on Polygon Amoy)
FARM_IDENTITY_CONTRACT_ADDRESS=0x...

# ===== OPTIONAL CONFIGURATION =====
# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
# IPFS configuration (for future use)
IPFS_API_URL=http://localhost:5001

