# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=farmtrust

# Server Configuration
PORT=8000
NODE_ENV=development

# Google Earth Engine Configuration
