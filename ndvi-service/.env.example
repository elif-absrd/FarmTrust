# ===== DATABASE CONFIGURATION =====
# PostgreSQL connection details
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=farmtrust

# ===== SERVER CONFIGURATION =====
# Python FastAPI server port
PORT=8000
# Environment mode (development, production)
NODE_ENV=development
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:3000

# ===== BACKEND SERVICE CONFIGURATION =====
# Backend service URL (for callbacks, CORS, etc.)
BACKEND_URL=http://localhost:5000

# ===== GOOGLE EARTH ENGINE CONFIGURATION =====
# Path to Google service account credentials JSON
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
# Your Google Earth Engine project ID
EE_PROJECT_ID=your_earth_engine_project_id

# ===== LOGGING =====
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

